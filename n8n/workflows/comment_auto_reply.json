      ]
    },
    "금칙어/광고/스팸 필터": {
      "main": [[{"node": "필터 통과?", "type": "main", "index": 0}]]
    },
    "필터 통과?": {
      "main": [
        [{"node": "댓글 의도 분류", "type": "main", "index": 0}],
        [{"node": "스팸 → 보류 처리", "type": "main", "index": 0}]
      ]
    },
    "댓글 의도 분류": {
      "main": [[{"node": "GPT 답변 생성", "type": "main", "index": 0}]]
    },
    "GPT 답변 생성": {
      "main": [[{"node": "YouTube 댓글 답글 게시", "type": "main", "index": 0}]]
    },
