# Gemini API
GOOGLE_API_KEY=your_gemini_api_key

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key

# Cloudflare Pages 배포
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_PAGES_PROJECT=your_pages_project

# Tistory
TISTORY_APP_ID=your_app_id
TISTORY_SECRET_KEY=your_secret_key
TISTORY_ACCESS_TOKEN=your_access_token
TISTORY_BLOG_NAME=your_blog_name
TISTORY_ENABLED=true

# Twitter/X (Phase 2)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_ENABLED=false

# Instagram (Phase 2)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
INSTAGRAM_ENABLED=false

# YouTube (Phase 3)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_ENABLED=false

# Schedule (KST)
PUBLISH_SCHEDULE_HOUR=9
PUBLISH_SCHEDULE_MINUTE=0
CONTENT_NICHE=투자/재테크

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ENABLED=false

# Instagram Graph API
META_ACCESS_TOKEN=
IG_USER_ID=
IG_REELS_ENABLED=false
INSTAGRAM_VIDEO_HOST_URL=

# Discord 알림 웹훅
DISCORD_WEBHOOK_URL=

# LLM 분석 모델 (기본값: Gemini Pro)
ANALYSIS_MODEL=google/gemini-2.5-pro-exp-0325:free

# 1차 LLM 백엔드 (gemini 또는 ollama)
LLM_PRIMARY_BACKEND=gemini

# Gemini CLI 모델 (기본값: gemini-2.5-flash)
GEMINI_CLI_MODEL=gemini-2.5-flash

# Ollama 로컬 모델
OLLAMA_MODEL=qwen3.6:35b-a3b
OLLAMA_TIMEOUT_SEC=300
OLLAMA_THINK_MODE=script

# Codex 모델
CODEX_MODEL=gpt-5.4-mini

# 영상 LLM 최적화 (OpenRouter HTTP 기반 고속 모델)
VIDEO_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
VIDEO_LLM_TIMEOUT_SEC=60
LLM_VIDEO_BACKEND=openrouter

# 영상 빌드 속도 최적화
SKIP_LONG_VIDEO=false
SHORT_DURATION_SEC=30
KENBURNS_PER_CHART_SEC=2

# 스크립트 강제 재생성
FORCE_REGEN_SCRIPT=false

# FFmpeg 영상 인코딩 설정
FFMPEG_VIDEO_CODEC=h264_nvenc
FFMPEG_PRESET=p1
